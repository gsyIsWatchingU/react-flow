{
  "name": "react-flow-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "predev": "pnpm --filter @react-flow/shared-types build",
    "dev": "concurrently \"pnpm --filter @react-flow/server dev\" \"pnpm --filter @react-flow/web dev\"",
    "dev:server": "pnpm --filter @react-flow/server dev",
    "dev:web": "pnpm --filter @react-flow/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.0"
  }
}
