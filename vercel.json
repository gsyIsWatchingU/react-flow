{
  "buildCommand": "pnpm --filter @react-flow/web build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "pnpm install",
  "rootDirectory": ".",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://react-flow-server.onrender.com/api/$1"
    }
  ]
}